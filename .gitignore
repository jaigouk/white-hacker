# Local working notes / scratch — never commit (global rule)
.notes/

# Local, machine-specific Claude Code settings (personal permissions)
.claude/settings.local.json
# Per-agent runtime memory (MEMORY.md-style scratch) — fragments across machines; use `bd remember`
.claude/agent-memory/
# Scheduler/wakeup runtime lock (session id + pid + timestamps) — ephemeral local state
.claude/scheduled_tasks.lock

# Security scan artifacts (generated per-run; never commit findings)
THREAT_MODEL.md.bak
SCAN-PLAN.json
VULN-FINDINGS.json
TRIAGE.json
SECRETS.json
DEPS.json
SECURITY-REPORT.md
PATCHES/
PATCH-STATE.json
.triage-state/
.patch-state/
*.sarif

# PUBLIC REPO — QA evidence + run/investigation logs are LOCAL-ONLY (they leak machine paths,
# installed-tool locations, and internal security posture). Keep producing under docs/qa/<date>/
# for local reference; NEVER commit. (Claude memory: public-repo-no-personal-info)
docs/qa/

# Exception: the PoC run evidence under docs/research/ is DELIBERATE, sanitized fixture
# output (planted-vuln findings — the eval-corpus seed), not live scans. Keep it tracked.
# (Also un-ignores triage.json, which the case-insensitive TRIAGE.json pattern catches on macOS.)
!docs/research/poc-floor-review/run/
!docs/research/poc-floor-review/run/*

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
.ruff_cache/
uv.lock

# Trivy / scanner caches
.trivycache/

# OS
.DS_Store

# Beads / Dolt: ignore everything under .beads/ except the version-controlled ticket data
# (mirrors the reference project — keeps the Dolt DB, hooks, metadata, backups OUT of git)
.beads/*
!.beads/issues.jsonl
!.beads/config.yaml
!.beads/README.md
!.beads/.gitignore
.dolt/
*.db
.beads-credential-key

# bd-generated shared settings (registers SessionStart/PreCompact `bd prime` hooks).
# Kept local like the reference project; un-ignore + commit deliberately to share with clones.
.claude/settings.json
